# ─── Server ───
APP_NAME=LuxeLife API
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8081
STATIC_BASE_URL=http://localhost:8000

# ─── Database (PostgreSQL) ───
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/luxelife

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0

# ─── JWT ───
JWT_ACCESS_SECRET=change-me-to-a-64-char-random-string-for-access-tokens
JWT_REFRESH_SECRET=change-me-to-a-64-char-random-string-for-refresh-tokens
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# ─── Razorpay ───
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxx

# ─── Google Cloud Storage ───
GCS_BUCKET=luxelife-uploads
GCS_CREDENTIALS_JSON=path/to/service-account.json

# ─── Firebase (Push Notifications) ───
FIREBASE_CREDENTIALS_JSON=path/to/firebase-service-account.json

# ─── Twilio (OTP / SMS) ───
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Sentry ───
SENTRY_DSN=SecurePass123!

